APP_ENV=local
TZ=Asia/Seoul

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173
AUTO_MIGRATE=true
AUTO_SEED_DEV=missing
AUTO_SEED_DUMMY_CONTENT=false
DUMMY_CONTENT_SEED_MODE=missing
DUMMY_CONTENT_BATCH_LABEL=dummy-content-v1
DUMMY_CONTENT_CARDS=100
DUMMY_CONTENT_REPLIES=100
DUMMY_CONTENT_KEYWORDS=100
DUMMY_CONTENT_ALLOW_PRODUCTION=false

POSTGRES_DB=maeumnamu
POSTGRES_USER=maeumnamu
POSTGRES_PASSWORD=maeumnamu_dev_password
