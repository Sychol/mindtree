POSTGRES_PORT=55432
DATABASE_URL=postgresql+psycopg://maeumnamu:maeumnamu_dev_password@postgres:5432/maeumnamu
TEST_DATABASE_URL=postgresql+psycopg://maeumnamu:maeumnamu_dev_password@postgres:55432/maeumnamu

TEST_JWT_SECRET_KEY=change-me-in-local-only
JWT_SECRET_KEY=change-me-in-local-only
JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRES_MINUTES=480
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
